# Copy this file and rename it to .env
# Fill in your actual values — never commit the real .env file

# Option 1: Use a full Neon DB connection string (recommended for Neon)
DATABASE_URL=postgresql://your_user:your_password@your_host/your_database?sslmode=require

# Option 2: Use individual fields (only if your main.py uses these separately)
# HOST=your_db_host
# PORT=5432
# DATABASE=your_database_name
# USER=your_db_user
# PASSWORD=your_db_password
